# Brand
NEXT_PUBLIC_APP_NAME="ArcRadar"
NEXT_PUBLIC_APP_TAGLINE="Discover projects building on Arc"

# Database — SQLite for dev, swap for Neon/Postgres URL in prod
DATABASE_URL="file:./dev.db"

# Admin auth (change this before deploying)
ADMIN_PASSWORD="change-me-now"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# Arc network
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_WSS_URL="wss://rpc.testnet.arc.network"
ARC_CHAIN_ID="5042002"
ARC_EXPLORER_URL="https://testnet.arcscan.app"

# Scanner (Phase 2)
SCANNER_ENABLED="false"
SCANNER_START_BLOCK="0"
SCANNER_POLL_INTERVAL_MS="15000"
